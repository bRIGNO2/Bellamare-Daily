# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bellamare_daily?schema=public"

# Server
PORT=4000
NODE_ENV=development

# Frontend URL (per CORS e cookie)
FRONTEND_URL="http://localhost:5173"

# JWT
JWT_SECRET="change-me-super-secret-key"
JWT_ADMIN_SECRET="change-me-another-super-secret-key"

# Regola di chiusura ordini (ora locale, 24h)
ORDER_CUTOFF_HOUR=19

# Fuso orario usato per il calcolo del cutoff
TIMEZONE="Europe/Rome"

# Seed admin (usati solo da prisma/seed.ts)
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="bellamare2026"
